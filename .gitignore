vllm-source/csrc/quantization/machete/generated/
.triton

# ============================================================================
# General Python / development
# ============================================================================

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
cmake-build-*/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.env
.venv
env/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover

# Type checking
.mypy_cache/

# Misc
*.log
*.tmp
*.temp
*.png
*.csv
*.pkl
*.hip

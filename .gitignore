data/
results/

# SLURM batch scripts
sbatch*

# Paper source
icml2026/
ICML___PPD/
rebuttal/
.claude/
CLAUDE.md
pyrightconfig.json

# Development files
basic_exp_data.xlsx

# Paper-specific & archived scripts
scripts/analysis/
scripts/experiments/
scripts/data/
scripts/benchmark/merge_*.py
scripts/benchmark/submit_*.sh
scripts/benchmark/synthetic_benchmark.py
scripts/benchmark/run_*.sh
scripts/tests/extreme_context_test.py
scripts/tests/high_qps_boundary_test.py
scripts/tests/test_oom_boundary.py

# ============================================================================
# vLLM build artifacts (inside vllm-source/)
# ============================================================================
vllm-source/vllm/_version.py
vllm-source/vllm/vllm_flash_attn/*
vllm-source/vllm/third_party/triton_kernels/*
vllm-source/csrc/moe/marlin_moe_wna16/kernel_*
